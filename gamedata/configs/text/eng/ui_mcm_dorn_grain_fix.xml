<?xml version="1.0" encoding="windows-1251"?>
<string_table>
	<string id="ui_mcm_menu_dorn_grain_fix">
		<text>Dorn's Radiation Grain Fix</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_main_description">
		<text>Grain intensity scales linearly with body radiation from 0 to 2000 mSv. Intensity is mapped between min and max, then multiplied by the scale.</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_intensity_scale">
		<text>Intensity scale</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_intensity_scale_desc">
		<text>Multiplier applied to the mapped grain intensity (0-1).</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_min_intensity">
		<text>Min intensity</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_min_intensity_desc">
		<text>Grain intensity at 0 mSv (0-1).</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_max_intensity">
		<text>Max intensity</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_max_intensity_desc">
		<text>Grain intensity at 2000 mSv (0-1).</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_preview_grain_key">
		<text>Preview grain</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_add_radiation_key">
		<text>Add radiation (+100 mSv)</text>
	</string>
	<string id="ui_mcm_dorn_grain_fix_debug_log">
		<text>Debug logging (on-screen)</text>
	</string>
</string_table>
